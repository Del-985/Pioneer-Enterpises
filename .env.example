# Shared API host used by the website, division apps, and admin panel.
VITE_API_BASE_URL=http://localhost:4000

# Show the shared debug toolbar in production-style frontend builds.
# Local Vite development also shows it automatically.
VITE_DEBUG_NAV=true

# Development only: bypass API authentication for protected admin routes.
# Never enable this in a production deployment.
VITE_ADMIN_DEBUG_BYPASS=false
