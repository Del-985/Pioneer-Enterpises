{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Pioneer Enterprises Admin",
  "version": "0.1.0",
  "identifier": "com.pioneerenterprises.admin",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Pioneer Enterprises Admin",
        "width": 1440,
        "height": 900,
        "minWidth": 1100,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "devtools": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "shortDescription": "Pioneer Enterprises administration panel",
    "longDescription": "Desktop administration and debugging shell for Pioneer Enterprises business panels."
  }
}
